<div id="landingContainer" style="display: none;">

    <!-- ═══════════════════════════════════════════════════════════════
         SIDEBAR  ·  mappé sur #lower pour la compatibilité JS
         Structure obligatoire : #left · #center · #right
         #center > #content  ←  requis par l'animation actualités
         ═══════════════════════════════════════════════════════════════ -->
    <div id="lower">

        <!-- ── PROFIL ──────────────────────────────── -->
        <div id="left">
            <div id="user_content">
                <div id="avatarContainer">
                    <img id="avatarImg" src="" alt="" draggable="false">
                </div>
                <div id="user_badge">
                    <span id="user_text"><%- lang('landing.usernamePlaceholder') %></span>
                </div>
            </div>
        </div>

        <!-- ── PARAMÈTRES ────────────────────────── -->
        <div id="center">
            <div id="content">

                <button class="dl-sidebar-btn" id="settingsMediaButton">
                    <svg id="settingsSVG" class="dl-sidebar-icon" viewBox="0 0 141.36 137.43">
                        <path d="M70.70475616319865,83.36934004916053 a15.320781354859122,15.320781354859122 0 1 1 14.454501310561755,-15.296030496450625 A14.850515045097694,14.850515045097694 0 0 1 70.70475616319865,83.36934004916053 M123.25082856443602,55.425620905968366 h-12.375429204248078 A45.54157947163293,45.54157947163293 0 0 0 107.21227231573047,46.243052436416285 l8.613298726156664,-9.108315894326587 a9.727087354538993,9.727087354538993 0 0 0 0,-13.167456673319956 l-3.465120177189462,-3.6631270444574313 a8.489544434114185,8.489544434114185 0 0 0 -12.375429204248078,0 l-8.613298726156664,9.108315894326587 A40.442902639482725,40.442902639482725 0 0 0 81.99114759747292,25.427580514871032 V12.532383284044531 a9.108315894326587,9.108315894326587 0 0 0 -8.811305593424633,-9.306322761594556 h-4.950171681699231 a9.108315894326587,9.108315894326587 0 0 0 -8.811305593424633,9.306322761594556 v12.895197230826497 a40.17064319698927,40.17064319698927 0 0 0 -9.331073620003052,4.0591407789933704 l-8.613298726156664,-9.108315894326587 a8.489544434114185,8.489544434114185 0 0 0 -12.375429204248078,0 L25.58394128451018,23.967279868769744 a9.727087354538993,9.727087354538993 0 0 0 0,13.167456673319956 L34.19724001066683,46.243052436416285 a45.07131316187151,45.07131316187151 0 0 0 -3.6631270444574313,9.083565035918088 h-12.375429204248078 a9.083565035918088,9.083565035918088 0 0 0 -8.811305593424633,9.306322761594556 v5.197680265784193 a9.108315894326587,9.108315894326587 0 0 0 8.811305593424633,9.306322761594556 h11.979415469712139 a45.69008462208391,45.69008462208391 0 0 0 4.0591407789933704,10.642869115653347 l-8.613298726156664,9.108315894326587 a9.727087354538993,9.727087354538993 0 0 0 0,13.167456673319956 l3.465120177189462,3.6631270444574313 a8.489544434114185,8.489544434114185 0 0 0 12.375429204248078,0 l8.613298726156664,-9.108315894326587 a40.49240435629971,40.49240435629971 0 0 0 9.331073620003052,4.0591407789933704 v12.895197230826497 a9.083565035918088,9.083565035918088 0 0 0 8.811305593424633,9.306322761594556 h4.950171681699231 A9.083565035918088,9.083565035918088 0 0 0 81.99114759747292,123.68848839660077 V110.79329116577425 a40.78941465720167,40.78941465720167 0 0 0 9.331073620003052,-4.0591407789933704 l8.613298726156664,9.108315894326587 a8.489544434114185,8.489544434114185 0 0 0 12.375429204248078,0 l3.465120177189462,-3.6631270444574313 a9.727087354538993,9.727087354538993 0 0 0 0,-13.167456673319956 l-8.613298726156664,-9.108315894326587 a45.665333763675406,45.665333763675406 0 0 0 4.034389920584874,-10.642869115653347 h12.004166328120636 a9.108315894326587,9.108315894326587 0 0 0 8.811305593424633,-9.306322761594556 v-5.197680265784193 a9.083565035918088,9.083565035918088 0 0 0 -8.811305593424633,-9.306322761594556 " class=""/>
                    </svg>
                    <span class="dl-sidebar-label">PARAMÈTRES</span>
                    <div id="settingsTooltip" style="display: none;"><%- lang('landing.settingsTooltip') %></div>
                </button>

            </div>
        </div>

        <!-- ── JOUER ─────────────────────────────────── -->
        <div id="right">
            <div id="launch_content">
                <button id="launch_button"><%- lang('landing.launchButton') %></button>
                <button id="server_selection_button"><%- lang('landing.launchButtonPlaceholder') %></button>
            </div>
        </div>

    </div><!-- /#lower (sidebar) -->

    <!-- ═══════════════════════════════════════════════════════════════
         ZONE PRINCIPALE  ·  mappée sur #upper
         Fond clair, branding en filigrane
         ═══════════════════════════════════════════════════════════════ -->
    <div id="upper">
        <div id="left"></div>
        <div id="content">
            <div id="dl-bento">

                <!-- ── Actualité principale (2 cols · row 1) ──────── -->
                <div class="dl-bc" id="dl-bc-news">
                    <div class="dl-bc-eyebrow">
                        <span class="dl-live-dot"></span>
                        ACTUALITÉS
                    </div>
                    <div class="dl-bc-news-thumb" id="dl-bc-news-thumb">
                        <img id="dl-bc-news-img" src="" alt="">
                    </div>
                    <div class="dl-bc-news-body">
                        <h3 id="dl-bc-news-title">Chargement&hellip;</h3>
                        <p id="dl-bc-news-excerpt"></p>
                    </div>
                    <span class="dl-bc-cta">LIRE LA SUITE &#8594;</span>
                </div>

                <!-- ── Infos serveur (1 col · row 1) ─────────────── -->
                <div class="dl-bc" id="dl-bc-server">
                    <div class="dl-bc-eyebrow">INFOS SERVEUR</div>
                    <div class="dl-bc-server-count" id="dl-bc-players">–</div>
                    <div class="dl-bc-server-label">joueurs en ligne</div>
                    <div class="dl-bc-server-spacer"></div>
                    <div class="dl-bc-server-name">DistrictLife</div>
                    <div class="dl-bc-server-version">Forge 1.16.5</div>
                </div>

                <!-- ── Discord (col 1 · row 2) ───────────────────── -->
                <div class="dl-bc dl-bc-link" id="dl-bc-discord">
                    <div class="dl-bc-link-icon dl-bc-icon-discord">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.032.054a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994.021-.041.001-.09-.041-.106a13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
                    </div>
                    <div class="dl-bc-link-label">DISCORD</div>
                    <div class="dl-bc-link-desc">Rejoins la communauté et suis les annonces</div>
                    <span class="dl-bc-cta">REJOINDRE &#8594;</span>
                </div>

                <!-- ── Voter (col 2 · row 2) ──────────────────────── -->
                <div class="dl-bc dl-bc-link" id="dl-bc-vote">
                    <div class="dl-bc-link-icon dl-bc-icon-vote">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/></svg>
                    </div>
                    <div class="dl-bc-link-label">VOTER</div>
                    <div class="dl-bc-link-desc">Vote chaque jour et gagne des récompenses</div>
                    <span class="dl-bc-cta">VOTER &#8594;</span>
                </div>

                <!-- ── Boutique (col 3 · row 2) ───────────────────── -->
                <div class="dl-bc dl-bc-link" id="dl-bc-store">
                    <div class="dl-bc-link-icon dl-bc-icon-store">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    </div>
                    <div class="dl-bc-link-label">BOUTIQUE</div>
                    <div class="dl-bc-link-desc">Grades, cosmétiques et bien plus</div>
                    <span class="dl-bc-cta">ACCÉDER &#8594;</span>
                </div>

            </div>
        </div>
        <div id="right"></div>

        <!-- Barre de progression — bas de la zone principale -->
        <div id="launch_details" style="display: none;">
            <progress id="launch_progress" value="0" max="100"></progress>
            <div id="launch_details_info">
                <span id="launch_progress_label">0%</span>
                <span id="launch_details_text"><%- lang('landing.launchDetails') %></span>
            </div>
        </div>

    </div>

    <!-- ═══════════════════════════════════════════════════════════════
         ZONE COMPAT  ·  éléments requis par le JS, non affichés
         ═══════════════════════════════════════════════════════════════ -->
    <div id="dl-compat">
        <!-- newsButton conservé ici pour compatibilité JS (onclick, alerts) -->
        <button id="newsButton" style="display:none;">
            <div id="newsButtonAlert" style="display:none;"></div>
            <span id="newsButtonText"><%- lang('landing.newsButton') %></span>
        </button>
        <div id="server_status_wrapper">
            <span id="landingPlayerLabel"><%- lang('landing.serverStatus') %></span>
            <span id="player_count"><%- lang('landing.serverStatusPlaceholder') %></span>
        </div>
        <div id="mojangStatusWrapper">
            <span id="mojang_status_icon">&#8226;</span>
            <div id="mojangStatusTooltip">
                <div id="mojangStatusTooltipTitle"><%- lang('landing.mojangStatusTooltipTitle') %></div>
                <div id="mojangStatusEssentialContainer"></div>
                <div id="mojangStatusNEContainer">
                    <div class="mojangStatusNEBar"></div>
                    <div id="mojangStatusNETitle"><%- lang('landing.mojangStatusNETitle') %></div>
                    <div class="mojangStatusNEBar"></div>
                </div>
                <div id="mojangStatusNonEssentialContainer"></div>
            </div>
        </div>
        <a href="<%- lang('landing.mediaGitHubURL') %>" id="linkURL"></a>
        <a href="<%- lang('landing.mediaXURL') %>" id="xURL"></a>
        <a href="<%- lang('landing.mediaInstagramURL') %>" id="instagramURL"></a>
        <a href="<%- lang('landing.mediaYouTubeURL') %>" id="youtubeURL"></a>
        <a href="<%- lang('landing.mediaDiscordURL') %>" id="discordURL"></a>
        <div id="image_seal_container"><div id="image_seal"></div></div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════
         PANNEAU ACTUALITÉS  ·  contrôlé par le JS
         ═══════════════════════════════════════════════════════════════ -->
    <div id="newsContainer">
        <div id="newsContent" article="-1" style="display: none;">
            <div id="newsStatusContainer">
                <div id="newsStatusContent">
                    <div id="newsTitleContainer">
                        <a id="newsArticleTitle" href="#">Lorem Ipsum</a>
                    </div>
                    <div id="newsMetaContainer">
                        <div id="newsArticleDateWrapper">
                            <span id="newsArticleDate">Mar 15, 44 BC, 9:14 AM</span>
                        </div>
                        <div id="newsArticleAuthorWrapper">
                            <span id="newsArticleAuthor">by Cicero</span>
                        </div>
                        <a href="#" id="newsArticleComments">0 Comments</a>
                    </div>
                </div>
                <div id="newsNavigationContainer">
                    <button id="newsNavigateLeft">
                        <svg id="newsNavigationLeftSVG" viewBox="0 0 24.87 13.97">
                            <defs>
                                <style>.arrowLine{fill:none;stroke:#FFF;stroke-width:2px;transition: 0.25s ease;}</style>
                            </defs>
                            <polyline class="arrowLine" points="0.71 13.26 12.56 1.41 24.16 13.02"/>
                        </svg>
                    </button>
                    <span id="newsNavigationStatus"><%- lang('landing.newsNavigationStatus', { currentPage: 1, totalPages: 1 }) %></span>
                    <button id="newsNavigateRight">
                        <svg id="newsNavigationRightSVG" viewBox="0 0 24.87 13.97">
                            <defs>
                                <style>.arrowLine{fill:none;stroke:#FFF;stroke-width:2px;transition: 0.25s ease;}</style>
                            </defs>
                            <polyline class="arrowLine" points="0.71 13.26 12.56 1.41 24.16 13.02"/>
                        </svg>
                    </button>
                </div>
            </div>
            <div id="newsArticleContainer">
                <div id="newsArticleContent">
                    <div id="newsArticleContentScrollable">
                        <!-- Article Content -->
                    </div>
                </div>
            </div>
        </div>
        <div id="newsErrorContainer">
            <div id="newsErrorLoading">
                <span id="nELoadSpan" class="newsErrorContent"><%- lang('landing.newsErrorLoadSpan') %></span>
            </div>
            <div id="newsErrorFailed" style="display: none;">
                <span id="nEFailedSpan" class="newsErrorContent"><%- lang('landing.newsErrorFailedSpan') %></span>
                <button id="newsErrorRetry"><%- lang('landing.newsErrorRetryButton') %></button>
            </div>
            <div id="newsErrorNone" style="display: none;">
                <span id="nENoneSpan" class="newsErrorContent"><%- lang('landing.newsErrorNoneSpan') %></span>
            </div>
        </div>
    </div>

    <script src="./assets/js/scripts/landing.js"></script>
</div>
